# Edge Function 시크릿 템플릿 (0017 지역 인증)
# ----------------------------------------------------------------------------
# 사용법:
#   1) 이 파일을 같은 폴더에 .env 로 복사한다 (실제 .env 는 .gitignore 로 커밋 안 됨)
#        cp supabase/functions/.env.example supabase/functions/.env
#   2) 아래 빈 값에 실제 키를 채운다 (따옴표 없이, = 뒤에 값만)
#   3) 원격 프로젝트에 시크릿 일괄 등록:
#        supabase secrets set --env-file supabase/functions/.env --project-ref vyatppuxmpulqtxevfpk
#      또는 한 줄씩:
#        supabase secrets set NAVER_MAP_KEY_ID=... NAVER_MAP_KEY=... --project-ref vyatppuxmpulqtxevfpk
#
# ⚠️ 실제 값을 적은 .env 는 절대 커밋하지 말 것. 이 .env.example 만 커밋한다.
# ----------------------------------------------------------------------------

# Naver Cloud Platform — Maps > Reverse Geocoding
#   - NAVER_MAP_KEY_ID : NCP 애플리케이션의 Client ID
#       (지도 SDK 와 같은 애플리케이션이면 main.dart 의 clientId 와 동일: cy02y6r0d5)
#   - NAVER_MAP_KEY    : 위 애플리케이션의 Client Secret
#       (지도 SDK 는 Secret 이 불필요해 지금까지 안 썼을 수 있음 → 콘솔 "인증 정보"에서 복사)
#   ※ 해당 애플리케이션에 'Reverse Geocoding' 서비스가 활성화돼 있어야 함.
NAVER_MAP_KEY_ID=
NAVER_MAP_KEY=

# 아래 3개는 이미 설정돼 있어 다시 넣지 않아도 됨(참고용):
#   JWT_SECRET                  — 로그인 JWT 검증 (기존 함수와 공유)
#   SUPABASE_URL                — 플랫폼 자동 주입
#   SUPABASE_SERVICE_ROLE_KEY   — 플랫폼 자동 주입
